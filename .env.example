# Punto único de entrada al Core mediante Kong API Gateway
VITE_API_BASE_URL=http://localhost:8000/api/v1

# Tiempo máximo de espera por petición HTTP (milisegundos)
VITE_REQUEST_TIMEOUT_MS=20000

# Anticipación para renovar/avisar la expiración de sesión (segundos)
VITE_SESSION_WARNING_SECONDS=120

# URL del frontend del Switch de Pagos Masivos. Dejar vacío mientras no esté desplegado.
VITE_SWITCH_PORTAL_URL=

# Activar únicamente cuando Core procese Idempotency-Key y Kong lo permita en CORS.
VITE_ENABLE_P2P_IDEMPOTENCY=false
